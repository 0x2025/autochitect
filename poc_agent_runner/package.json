{
  "name": "autochitect",
  "version": "1.1.0",
  "description": "Autonomous AI Architect for codebase analysis and C4 reporting",
  "main": "dist/index.js",
  "bin": {
    "autochitect": "./dist/cli.js"
  },
  "files": [
    "dist",
    "registry.json",
    "moat",
    "README.md"
  ],
  "scripts": {
    "start": "ts-node src/index.ts",
    "seed": "ts-node src/seed.ts",
    "test:eval": "ts-node src/index.ts --test-eval",
    "test:regression": "NODE_OPTIONS='--max-old-space-size=6144' ts-node --transpile-only tests/regression_eval.ts",
    "test:grounding": "ts-node src/index.ts --test-grounding",
    "validate:registry": "ts-node scripts/validate_registry.ts",
    "build": "tsc",
    "build:cli": "esbuild src/cli.ts src/index.ts --bundle --platform=node --target=node20 --outdir=dist --packages=external",
    "build:docker": "esbuild src/index.ts --bundle --platform=node --target=node20 --outdir=dist --packages=external",
    "prepublishOnly": "npm run build:cli"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.30",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/google-vertexai": "^2.1.24",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1",
    "simple-git": "^3.32.3",
    "tree-sitter": "^0.21.0",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.21.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}