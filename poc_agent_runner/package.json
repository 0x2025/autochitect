{
  "name": "poc_agent_runner",
  "version": "1.0.0",
  "description": "Proof of concept for the LangGraph-based Execution Runner",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "seed": "ts-node src/seed.ts",
    "test:eval": "ts-node src/index.ts --test-eval",
    "test:regression": "NODE_OPTIONS='--max-old-space-size=6144' ts-node --transpile-only tests/regression_eval.ts",
    "test:grounding": "ts-node src/index.ts --test-grounding",
    "validate:registry": "ts-node scripts/validate_registry.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@langchain/core": "^0.3.80",
    "@langchain/google-genai": "^0.1.12",
    "@langchain/langgraph": "^0.2.74",
    "dotenv": "^16.6.1",
    "simple-git": "^3.32.3",
    "tree-sitter": "^0.21.0",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.21.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}